# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.

# ── GitHub App ────────────────────────────────────────────────────────────────
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here
GITHUB_TOKEN=ghp_your_token_here

# ── AI provider ───────────────────────────────────────────────────────────────
# Set to "anthropic" (default) or "qwen".
# Only the key for the selected provider is required.
AI_PROVIDER=anthropic

# ── Anthropic (required when AI_PROVIDER=anthropic) ──────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Qwen / Alibaba DashScope (required when AI_PROVIDER=qwen) ────────────────
# Get your key at: https://dashscope.aliyun.com/
# Models: qwen-plus (balanced), qwen-turbo (fast/cheap), qwen-max (best quality)
QWEN_API_KEY=sk-your-dashscope-key-here
QWEN_MODEL=qwen-plus
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://securecommit:securecommit@postgres:5432/securecommit
DATABASE_URL_SYNC=postgresql+psycopg2://securecommit:securecommit@postgres:5432/securecommit

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
